# Artha AI — Environment Configuration Template
# Copy to .env and fill in values. Never commit .env to Git.

# Application
ENV=development
SECRET_KEY=artha_docker_build_placeholder_secret_key

# User credentials (loaded at startup — never hardcode in source)
ARTHA_ADMIN_USERNAME=admin
ARTHA_ADMIN_PASSWORD=ArthaDemoAdmin2026!
ARTHA_ANALYST_USERNAME=analyst
ARTHA_ANALYST_PASSWORD=ArthaDemoAnalyst2026!
ARTHA_READONLY_USERNAME=readonly
ARTHA_READONLY_PASSWORD=ArthaDemoReadOnly2026!

# AI APIs
GROQ_API_KEY=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
GEMINI_API_KEY=

# Database (leave blank to use SQLite fallback)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=artha_db
POSTGRES_USER=artha_admin
POSTGRES_PASSWORD=

# Cache (leave blank to use MockRedis fallback)
REDIS_HOST=localhost
REDIS_PORT=6379

# Streaming (leave blank to use MockKafka fallback)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Compliance
USD_INR_RATE=84.0
USD_INR_RATE_DATE=2026-05-01
